# Copia este archivo como .env y ajusta los valores

# OpenAI — usado por gpt-4o-mini (cotizacion) y whisper-1 (transcripcion de voz)
OPENAI_API_KEY=tu_openai_key_aqui

# Telegram — token del bot de cotizaciones (obtener en @BotFather)
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui

# PostgreSQL — opcional. Si se deja vacio, la auditoria de cotizaciones queda desactivada.
# Formato: postgresql://usuario:password@host:puerto/dbname
DATABASE_URL=
