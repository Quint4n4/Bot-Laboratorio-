# Normalizacion de line endings — evita falsos diffs CRLF/LF
# Cualquier editor en Windows o Linux escribira el archivo como decida,
# pero git almacenara LF en el repositorio.

* text=auto eol=lf

# Archivos de codigo / texto explicitamente LF
*.py        text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
.env*       text eol=lf
Dockerfile  text eol=lf
Procfile    text eol=lf

# Binarios — git no los toca
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.ico       binary
*.mp3       binary
*.ogg       binary
*.wav       binary
*.zip       binary
*.gz        binary
