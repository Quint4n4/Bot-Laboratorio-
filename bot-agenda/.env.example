# Copia este archivo como .env y ajusta los valores
# Bot de Agenda Personal "CAMSI"

# ─── Telegram ──────────────────────────────────────────────────
# Token del bot (obtenerlo en @BotFather)
TELEGRAM_TOKEN=tu_token_aqui_obtenido_en_botfather

# ─── OpenAI ────────────────────────────────────────────────────
# Usado para: GPT (function calling), Whisper (STT), TTS-1-HD (voz)
OPENAI_API_KEY=sk-proj-tu_clave_de_openai_aqui

# ─── Base de datos PostgreSQL (REQUERIDA) ──────────────────────
# El bot crashea al arrancar si esta variable no esta definida.
# Compartida con el dashboard. En Railway/Supabase usa el pooler 6543.
# Formato: postgresql://usuario:password@host:puerto/dbname
DB_URL_REAL=postgresql://usuario:password@host:6543/postgres

# ─── Dashboard (Streamlit) ─────────────────────────────────────
# Secreto HMAC para firmar magic links. Debe coincidir EXACTO con
# el DASHBOARD_SECRET configurado en Streamlit Cloud.
DASHBOARD_SECRET=cadena_aleatoria_larga_y_secreta

# ─── Configuracion regional ────────────────────────────────────
TIMEZONE=America/Mexico_City

# ─── Voz ───────────────────────────────────────────────────────
# Voz por defecto de OpenAI TTS: nova | shimmer | alloy | echo | fable | onyx
VOICE_PERSONA=nova

# ─── ElevenLabs (opcional, migracion futura) ───────────────────
# Pendiente de aceptacion de presupuesto. Cuando se active, el bot
# usara ElevenLabs en lugar de OpenAI TTS para voz mas natural.
ELEVENLABS_API_KEY=
